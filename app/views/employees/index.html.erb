<div class="col-lg-12">
    <%= flash[:notice] %>
    <div class="card rounded-0 mt-5 mb-5">
        <div class="card-body">
            <h2 class="text-center">Listing Employees Details</h2>
        </div>
    </div>
    <%= link_to 'Create New Employee', new_employee_path, class:'btn btn-primary btn-lg' %>
    <table class ="table table-bordered mt-3">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Country</th>
                <th>Address</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% @employees.each do |employee|%>
                <tr>
                    <td> <%= employee.name %> </td>
                    <td> <%= employee.personal_email %> </td>
                    <td> <%= employee.country %> </td>
                    <td> <%= employee.full_address %>  </td>
                    <td><%= link_to 'Edit', edit_employee_path(employee)%></th>
                </tr>
            <% end %>
        </tbody>
    </table>
</div>